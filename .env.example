LIVED_HTTP_ADDR=:8080
LIVED_AUTO_MIGRATE=true
LIVED_GAME_TICK_INTERVAL=1s
LIVED_GAME_MINUTES_PER_REAL_MINUTE=60

LIVED_POSTGRES_HOST=127.0.0.1
LIVED_POSTGRES_PORT=5432
LIVED_POSTGRES_USER=lived
LIVED_POSTGRES_PASSWORD=change_me
LIVED_POSTGRES_DBNAME=lived
LIVED_POSTGRES_ADMIN_DB=postgres
LIVED_POSTGRES_SSLMODE=disable
LIVED_POSTGRES_TIMEZONE=UTC

# Optional override. When set, this DSN is used directly instead of LIVED_POSTGRES_* fields.
# LIVED_DATABASE_URL=host=127.0.0.1 user=lived password=change_me dbname=lived port=5432 sslmode=disable TimeZone=UTC

# Optional frontend dev proxy. When set (e.g. http://localhost:5173), Go proxies non-API routes to Vite for HMR.
# LIVED_WEB_DEV_PROXY_URL=http://localhost:5173

# MMO auth feature flag and JWT settings.
LIVED_MMO_AUTH_ENABLED=false
# LIVED_MMO_REALM_SCOPING_ENABLED=true
# LIVED_MMO_CHAT_ENABLED=true
# LIVED_MMO_ADMIN_ENABLED=true
# LIVED_MMO_OTEL_ENABLED=false
# LIVED_MMO_JWT_SECRET=change_me_for_real_deployments
LIVED_MMO_JWT_ISSUER=lived
LIVED_MMO_ACCESS_TOKEN_TTL=15m
LIVED_MMO_REFRESH_TOKEN_TTL=720h

# Optional write-route rate limiting controls.
# LIVED_RATE_LIMIT_ENABLED=false
# LIVED_RATE_LIMIT_WINDOW=1m
# LIVED_RATE_LIMIT_AUTH_MAX=20
# LIVED_RATE_LIMIT_CHAT_MAX=30
# LIVED_RATE_LIMIT_BEHAVIOR_MAX=30
# LIVED_RATE_LIMIT_ONBOARD_MAX=10
# LIVED_RATE_LIMIT_IDENTITY=ip # ip | account_or_ip

# Optional write-route idempotency controls.
# LIVED_IDEMPOTENCY_ENABLED=false
# LIVED_IDEMPOTENCY_TTL=10m

# Optional MMO stream connection limits (enforced when MMO auth is enabled).
# LIVED_STREAM_MAX_CONNS_PER_ACCOUNT=5
# LIVED_STREAM_MAX_CONNS_PER_SESSION=2
