LIVED_HTTP_ADDR=:8080
LIVED_AUTO_MIGRATE=true
LIVED_GAME_TICK_INTERVAL=1s
LIVED_GAME_MINUTES_PER_REAL_MINUTE=60

LIVED_POSTGRES_HOST=127.0.0.1
LIVED_POSTGRES_PORT=5432
LIVED_POSTGRES_USER=lived
LIVED_POSTGRES_PASSWORD=change_me
LIVED_POSTGRES_DBNAME=lived
LIVED_POSTGRES_ADMIN_DB=postgres
LIVED_POSTGRES_SSLMODE=disable
LIVED_POSTGRES_TIMEZONE=UTC

# Optional override. When set, this DSN is used directly instead of LIVED_POSTGRES_* fields.
# LIVED_DATABASE_URL=host=127.0.0.1 user=lived password=change_me dbname=lived port=5432 sslmode=disable TimeZone=UTC

# Optional frontend dev proxy. When set (e.g. http://localhost:5173), Go proxies non-API routes to Vite for HMR.
# LIVED_WEB_DEV_PROXY_URL=http://localhost:5173
